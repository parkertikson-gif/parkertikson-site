---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import '../styles/masters.css';

type Degree = 'masters';

interface Props {
  degree: Degree;
}
const { degree } = Astro.props;

interface DegreeConfig {
  label: string;
  pageTitle: string;
  pageDescription: string;
  headline: string;
  deck: string;
  programLine: string;
  spanLine: string;
  terms: string[];
}

const configs: Record<Degree, DegreeConfig> = {
  masters: {
    label: "Master's",
    pageTitle: "Master's — Parker Tikson",
    pageDescription: "A working archive of master's coursework at UC Berkeley — Civil & Environmental Engineering, with a focus on energy, infrastructure, and climate.",
    headline: "Master's coursework",
    deck: "A working archive of the projects from my one year studying civil & environmental engineering at Berkeley. Each course links to the final deliverable, with a short note on what it was about and what I did.",
    programLine: 'M.S., Civil & Environmental Engineering · UC Berkeley',
    spanLine: '2025 — 2026',
    terms: ['Fall 2025', 'Spring 2026'],
  },
};

const cfg = configs[degree];

const all = await getCollection('courses');
const courses = all.filter(e => e.data.degree === degree);

const grouped = cfg.terms
  .map(term => ({
    name: term,
    courses: courses.filter(e => e.data.term === term),
  }))
  .filter(g => g.courses.length > 0);

const slugOf = (id: string) => id.split('/').pop()!;
const degreeHref = `/${degree}`;
---
<Layout title={cfg.pageTitle} description={cfg.pageDescription}>

  <nav class="breadcrumb">
    <a href="/">Home</a>
    <span class="sep">/</span>
    <span>{cfg.label}</span>
  </nav>

  <header class="degree-header">
    <h1>{cfg.headline}</h1>
    <p class="program">{cfg.programLine}<span class="sep"> · </span>{cfg.spanLine}</p>
    <p class="deck">{cfg.deck}</p>
  </header>

  <section class="terms">
    {grouped.map(group => (
      <div class="term">
        <h2 class="term-name">{group.name}</h2>
        <ul class="courses">
          {group.courses.map(course => {
            const d = course.data;
            const slug = slugOf(course.id);
            const hasPage = d.hasPage !== false;
            return (
              <li class="course">
                {hasPage ? (
                  <a href={`${degreeHref}/${slug}`} class="row">
                    <span class="code">{d.code}</span>
                    <span class="title">{d.title}</span>
                    <span class="deck">{d.deck}</span>
                    {d.grade && <span class="grade">{d.grade}</span>}
                  </a>
                ) : (
                  <div class="row no-page">
                    <span class="code">{d.code}</span>
                    <span class="title">{d.title}</span>
                    <span class="deck">{d.deck}</span>
                    {d.grade && <span class="grade">{d.grade}</span>}
                  </div>
                )}
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </section>

</Layout>
