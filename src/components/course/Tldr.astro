---
interface Stat {
  num: string;
  unit?: string;
  label: string;
}
interface Props {
  statement: string;
  stats: Stat[];
}
const { statement, stats } = Astro.props;
---
<section class="tldr">
  <div class="tldr-grid">
    <p class="tldr-stmt" set:html={statement} />
    {stats.map(s => (
      <div class="stat">
        <div class="num">{s.num}{s.unit && <span class="unit">{s.unit}</span>}</div>
        <div class="lbl" set:html={s.label} />
      </div>
    ))}
  </div>
</section>
