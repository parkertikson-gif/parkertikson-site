---
interface Props {
  num: string;          // "01"
  label: string;        // "Problem"
  title: string;        // "A planning tool that can't keep up..."
  gutter?: string[];
}
const { num, label, title, gutter = [] } = Astro.props;
---
<div class="sec-head">
  <div class="sec-num">§ {num} — {label}</div>
  <h2 class="sec-title" set:html={title} />
</div>
<div class="sec-body">
  <div class="gutter" set:html={gutter.join('<br>')} />
  <div>
    <slot />
  </div>
</div>
