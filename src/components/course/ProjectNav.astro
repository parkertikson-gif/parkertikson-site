---
interface Course { slug: string; title: string; }
interface Props {
  degree: 'masters' | 'bachelors';
  prev?: Course;
  next?: Course;
}
const { degree, prev, next } = Astro.props;
const base = degree === 'masters' ? '/masters' : '/bachelors';
---
<nav class="proj-nav">
  {prev ? (
    <a class="prev" href={`${base}/${prev.slug}`}>
      <span class="dir">← Previous</span>
      <span class="ttl">{prev.title}</span>
    </a>
  ) : <span />}
  {next && (
    <a class="next" href={`${base}/${next.slug}`}>
      <span class="dir">Next →</span>
      <span class="ttl">{next.title}</span>
    </a>
  )}
</nav>
