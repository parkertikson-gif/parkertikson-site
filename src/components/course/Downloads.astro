---
interface Download {
  type: string;
  label: string;
  href: string;
}
interface Props { downloads: Download[]; }
const { downloads } = Astro.props;
---
<div class="downloads">
  <div class="gutter">Artifacts</div>
  <div class="dl-grid">
    {downloads.map(d => (
      <a class="dl" href={d.href}>
        <span class="dl-type">{d.type}</span>
        <span class="dl-name">{d.label}</span>
        <span class="dl-arrow">↗</span>
      </a>
    ))}
  </div>
</div>
