---
interface Props {
  degree: 'masters' | 'bachelors';
  courseTitle?: string;
}
const { degree, courseTitle } = Astro.props;
const degreeLabel = degree === 'masters' ? "Master's" : "Bachelor's";
const degreeHref = degree === 'masters' ? '/masters' : '/bachelors';
---
<nav class="breadcrumb">
  <a href="/">Home</a>
  <span class="sep">/</span>
  <a href={degreeHref}>{degreeLabel}</a>
  {courseTitle && <>
    <span class="sep">/</span>
    <span>{courseTitle}</span>
  </>}
</nav>
