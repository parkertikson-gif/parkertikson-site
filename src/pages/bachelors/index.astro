---
<Layout title="Bachelor's — Parker Tikson" description="Geophysical Sciences at the University of Chicago — the undergraduate foundation behind the master's work.">

  <nav class="breadcrumb">
    <a href="/">Home</a>
    <span class="sep">/</span>
    <span>Bachelor's</span>
  </nav>

  <header class="degree-header">
    <h1>Bachelor's coursework</h1>
    <p class="program">B.S., Geophysical Sciences · University of Chicago<span class="sep"> · </span>2012 — 2016, With General Honors</p>
    <p class="deck">
      <em>A longer reflection is in progress. For now, the transcript speaks.</em>
    </p>
  </header>

  <section class="transcript">
    {quarters.map(q => (
      <div class="quarter">
        <h2 class="quarter-name">
          {q.name}
          {q.location && <span class="loc"> · {q.location}</span>}
        </h2>
        <ul class="courses">
          {q.courses.map(c => (
            <li class="row">
              <span class="code">{c.code}</span>
              <span class="title">{c.title}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>

  <section class="beyond">
    <h2>Beyond the transcript</h2>
    <ul class="beyond-list">
      {beyond.map(b => (
        <li>
          <div class="b-head">
            <span class="b-label">{b.label}</span>
            <span class="b-meta">{b.meta}</span>
          </div>
          <p class="b-text">{b.text}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="gave-me">
    <h2>What this gave me</h2>
    <p>
      <em>A reflection is in progress.</em>
    </p>
  </section>

</Layout>
