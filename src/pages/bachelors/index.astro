---
import Layout from '../../layouts/Layout.astro';
import '../../styles/masters.css';
import '../../styles/bachelors.css';

interface QuarterCourse {
  code: string;
  title: string;
}
interface Quarter {
  name: string;
  courses: QuarterCourse[];
  location?: string;
}

const quarters: Quarter[] = [
