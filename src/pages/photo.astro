---
<Layout title="Photo — Parker Tikson" description="A loose archive of photographs by Parker Tikson — no themes, just whatever asked to be photographed." bodyClass="photo-page">

  <header class="page">
    <div class="h-row">
      <div class="h-left">
        <span class="h-tag">§ Photo</span>
        <h1>Things I noticed, <em>kept</em>.</h1>
      </div>
      <div class="h-right">
        <div><span class="ct">{placeholders.length}</span> images</div>
        <div>2019 — present</div>
      </div>
    </div>
    <p class="h-prose">
      A loose archive. Some of it published, most of it just for me — but always whatever asked to be photographed.
      Click any image to see it bigger.
    </p>
  </header>

  <div class="mosaic" id="mosaic">
    {placeholders.map(p => (
      <div class="photo">
        <div class="frame">
          <svg class="placeholder" viewBox={p.vb} xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice" set:html={p.svg} />
        </div>
      </div>
    ))}
  </div>

  <section class="colophon-strip">
    <div class="col-item">
      <span class="lbl">Published with</span>
      <span class="val">The New York Times
        <span class="sub">Ski Magazine</span>
      </span>
    </div>
    <div class="col-item">
      <span class="lbl">Partner with</span>
      <span class="val">Washington National Park Fund
        <span class="sub">2018 — 2023 · Edge Outdoors, 2021 — 2025</span>
      </span>
    </div>
    <div class="col-item">
      <span class="lbl">Prints</span>
      <span class="val">Available on request
        <span class="sub">For a friend or a wall, drop a line</span>
      </span>
    </div>
  </section>

  <div class="lb" id="lb">
    <button class="lb-close" type="button">Close ✕</button>
    <div class="lb-stage" id="lb-stage"></div>
    <div class="lb-meta" id="lb-meta">— / —</div>
  </div>

</Layout>

<script>
  const lb = document.getElementById('lb')!;
  const stage = document.getElementById('lb-stage')!;
  const lbMeta = document.getElementById('lb-meta')!;
  const photos = document.querySelectorAll<HTMLElement>('.photo');
  const total = String(photos.length).padStart(2, '0');

  photos.forEach((p, i) => {
    p.addEventListener('click', () => {
      const svg = p.querySelector('svg')?.cloneNode(true) as SVGElement | undefined;
      if (!svg) return;
      stage.replaceChildren(svg);
      lbMeta.textContent = `${String(i + 1).padStart(2, '0')} / ${total}`;
      lb.classList.add('open');
    });
  });

  lb.addEventListener('click', e => {
    const target = e.target as HTMLElement;
    if (target === lb || target.classList.contains('lb-close')) {
      lb.classList.remove('open');
    }
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') lb.classList.remove('open');
  });
</script>
