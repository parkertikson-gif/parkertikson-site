---
import { Picture, getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import '../styles/photo.css';

const photoModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/photos/*.jpg',
  { eager: true },
);

const photos = await Promise.all(
  Object.entries(photoModules)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(async ([path, mod]) => {
      const src = mod.default;
      const filename = path.split('/').pop()!.replace(/\.jpg$/, '');
      const alt = filename
        .replace(/^\d+-/, '')
        .replace(/-/g, ' ');
      const full = await getImage({
        src,
        width: Math.min(src.width, 1800),
        format: 'webp',
        quality: 85,
      });
      return { src, alt, fullSrc: full.src };
    }),
);

const total = String(photos.length).padStart(2, '0');
---
<Layout title="Photography — Parker Tikson" description="A loose archive of photographs by Parker Tikson — no themes, just whatever asked to be photographed." bodyClass="photo-page">

  <header class="photo-header">
    <h1>Things I noticed, kept.</h1>
    <p class="deck">A loose archive. No themes, no series — just whatever asked to be photographed.</p>
  </header>

  <div class="mosaic" id="mosaic">
    {photos.map((photo, i) => (
      <button
        class="photo"
        type="button"
        data-full={photo.fullSrc}
        data-index={String(i + 1).padStart(2, '0')}
        aria-label={`Open photo ${i + 1} of ${photos.length}`}
      >
        <div class="frame">
          <Picture
            src={photo.src}
            alt={photo.alt}
            widths={[400, 800, 1200]}
            sizes="(max-width: 640px) 100vw, (max-width: 1100px) 50vw, 33vw"
            formats={['webp']}
            fallbackFormat="jpg"
            quality={82}
            loading={i < 3 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </div>
      </button>
    ))}
  </div>

  <section class="colophon-strip">
    <div class="col-item">
      <span class="lbl">Published with</span>
      <span class="val">The New York Times<span class="sub">Ski Magazine</span></span>
    </div>
    <div class="col-item">
      <span class="lbl">Partner with</span>
      <span class="val">Washington National Park Fund<span class="sub">2018 — 2023</span></span>
    </div>
    <div class="col-item">
      <span class="lbl">Partner with</span>
      <span class="val">Edge Outdoors<span class="sub">2021 — 2025</span></span>
    </div>
  </section>

  <div class="lb" id="lb" aria-hidden="true">
    <button class="lb-close" type="button">Close</button>
    <div class="lb-stage" id="lb-stage"></div>
    <div class="lb-meta" id="lb-meta">— / {total}</div>
  </div>

</Layout>

<script>
  const lb = document.getElementById('lb')!;
  const stage = document.getElementById('lb-stage')!;
  const lbMeta = document.getElementById('lb-meta')!;
  const photos = document.querySelectorAll<HTMLElement>('.photo');
  const total = String(photos.length).padStart(2, '0');

  const open = (full: string, index: string, alt: string) => {
    const img = document.createElement('img');
    img.src = full;
    img.alt = alt;
    stage.replaceChildren(img);
    lbMeta.textContent = `${index} / ${total}`;
    lb.classList.add('open');
    lb.setAttribute('aria-hidden', 'false');
  };

  const close = () => {
    lb.classList.remove('open');
    lb.setAttribute('aria-hidden', 'true');
    stage.replaceChildren();
  };

  photos.forEach(p => {
    p.addEventListener('click', () => {
      const full = p.dataset.full;
      const index = p.dataset.index;
      const alt = p.querySelector('img')?.alt ?? '';
      if (!full || !index) return;
      open(full, index, alt);
    });
  });

  lb.addEventListener('click', e => {
    const target = e.target as HTMLElement;
    if (target === lb || target.classList.contains('lb-close')) close();
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && lb.classList.contains('open')) close();
  });
</script>
