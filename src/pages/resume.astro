  },
  {
    type: 'work',
    when: '2021 — 2024',
    title: 'Sr. Technical Product Manager · Workforce Science and Strategy',
    org: 'Amazon · Seattle, WA',
    body: "Owned end-to-end development for Amazon's internal Workforce Management System — a suite of workforce planning tools enabling the first fully-automated flexible workforce at scale (>100,000 associates, $1.2B in shift costs), eliminating $61M in labor costs annually. Led 25+ engineers across Software, Data Engineering, BI, Applied Data Science, and UX. Continuously led prioritization across Operations, Strategy, HR, Finance, and Tech.",
    skills: ['python', 'ml', 'research'],
  },
  {
    type: 'work',
    when: '2019 — 2021',
    title: 'Product Manager II · Global Specialty Fulfillment',
    org: 'Amazon · Seattle, WA',
    body: "Led 0-to-1 development of a prototype workforce planning system for Whole Foods & Sub-Same-Day operations, cutting workload by 95%. Built a team of 3 to rebuild it as a web-app, scaling to >$800M of shifts annually.",
    skills: ['python', 'research'],
  },
  {
    type: 'work',
    when: '2018 — 2019',
    title: 'Program Manager II · Prime Now & Central Operations',
    org: 'Amazon · Seattle, WA',
    body: 'Launched Central Operations org. Built change-management and documentation system standardizing 500+ ops processes. Automated 40+ previously manual processes.',
    skills: ['research'],
  },
  {
    type: 'work',
    when: '2016 — 2018',
    title: 'Program Manager I · Prime Now',
    org: 'Amazon · Seattle, WA',
    body: "Supported development of three prototype systems powering Amazon's first 2-hour delivery option. Reduced grocery delivery from 4 hours to 2 hours, cut cost-per-delivery by nearly 50%. Managed customer-facing rollout of one-hour delivery (>30% of orders).",
    skills: ['research'],
  },
  {
    type: 'work',
    when: '2016',
    title: 'Program Manager',
    org: 'Pritzker School of Molecular Engineering · Chicago, IL',
    body: "Pioneered the first-ever 3D-printed microfluidic device master template, slashing custom development costs by 99% (from $1,400 to $11). Designed student programs and lab protocols to establish the university's first Intro to Molecular Engineering course.",
    skills: ['research'],
  },
  {
    type: 'work',
